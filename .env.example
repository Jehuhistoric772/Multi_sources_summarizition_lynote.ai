# AI Summary Skill - API Key Configuration
# Copy this file to .env and fill in the keys you need.
# Only configure the levels you want to use.

# === Level 2: Large Document Support (PDF >5 pages) ===
# Azure Document Intelligence - high-speed PDF extraction
# Get it: Azure Portal → Create "Document Intelligence" resource
# Free tier: 500 pages/month
# AZURE_DI_ENDPOINT=https://your-instance.cognitiveservices.azure.com
# AZURE_DI_KEY=your_key_here

# === Level 3: YouTube Video Support ===
# Supadata - YouTube transcript extraction
# Get it: https://supadata.ai/
# Free tier: 50 requests/month
# SUPADATA_API_KEY=your_key_here

# === Level 4: Audio/Video File Support ===
# Deepgram Nova-3 - audio/video transcription
# Get it: https://deepgram.com/
# Free tier: $200 credit
# DEEPGRAM_API_KEY=your_key_here
